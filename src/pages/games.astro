---
import Layout from '../layouts/Layout.astro';

const experiments = [
  { title: 'Space Invaders', summary: 'A browser-native shooter focused on wave logic, collision feedback, particles, and a clear game-state loop.', href: '/games/space-invaders', source: 'https://github.com/BryanPMX/Professional_Portfolio/blob/main/src/pages/games/space-invaders.astro', image: '/assets/space-invaders.webp', alt: 'Space Invaders browser game with player ship, enemies, score, and lives' },
  { title: 'Snake', summary: 'A compact arcade loop with deterministic grid movement, progressive speed, score persistence, and keyboard controls.', href: '/games/snake', source: 'https://github.com/BryanPMX/Professional_Portfolio/blob/main/src/pages/games/snake.astro', image: '/assets/snake-game.webp', alt: 'Snake browser game on a dark grid with score and controls' },
];
---

<Layout title="Engineering Lab" description="Playable browser experiments and small systems built by Bryan Perez.">
  <section class="lab-hero section-pad shell reveal is-visible">
    <div><p class="eyebrow">Engineering lab</p><h1 class="page-title">Small systems. Fast feedback. <span class="signal-text">Playable proof.</span></h1></div>
    <p class="lede">The lab is intentionally secondary to production case studies. It is where I explore state, input, rendering, and feedback loops directly in the browser.</p>
  </section>

  <section class="lab-list section-rule section-pad">
    <div class="shell lab-grid">
      {experiments.map((experiment, index) => (
        <article class="experiment surface hover-lift reveal">
          <a href={experiment.href} class="experiment-image"><img src={experiment.image} alt={experiment.alt} width="1600" height="1000" loading="lazy" decoding="async" /></a>
          <div class="experiment-body">
            <div class="experiment-meta"><span>0{index + 1} / Browser game</span><span>JavaScript · Canvas</span></div>
            <h2><a href={experiment.href}>{experiment.title}</a></h2>
            <p>{experiment.summary}</p>
            <div><a href={experiment.href} class="button button-primary">Play now</a><a href={experiment.source} class="button button-secondary" target="_blank" rel="noopener noreferrer">Source ↗</a></div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="lab-note section-pad shell reveal">
    <p class="eyebrow">Why keep a lab?</p><h2 class="section-title">Interaction work reveals engineering judgment quickly.</h2>
    <div><p>State transitions</p><p>Input latency</p><p>Collision and timing</p><p>Failure and restart</p></div>
  </section>
</Layout>

<style>
  .lab-hero { display: grid; grid-template-columns: minmax(0,1.15fr) minmax(20rem,.85fr); gap: clamp(3rem,8vw,8rem); align-items: end; padding-top: clamp(5rem,10vw,8.5rem); }
  .lab-hero h1 { margin-top: 1rem; }
  .lab-hero .lede { font-size: 1rem; }
  .lab-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1rem; }
  .experiment { overflow: hidden; }
  .experiment-image { display: block; overflow: hidden; border-bottom: 1px solid var(--line); background: #06090d; }
  .experiment-image img { width: 100%; aspect-ratio: 16/10; object-fit: cover; transition: transform 300ms ease, filter 300ms ease; filter: saturate(.78); }
  .experiment:hover img { transform: scale(1.025); filter: saturate(1); }
  .experiment-body { padding: clamp(1.3rem,3vw,2rem); }
  .experiment-meta { display: flex; align-items: center; justify-content: space-between; gap: 1rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .6rem; }
  .experiment h2 { margin: 1.5rem 0 .7rem; font-size: clamp(1.6rem,3vw,2.4rem); letter-spacing: -.04em; }
  .experiment-body > p { min-height: 4.5rem; margin: 0 0 1.5rem; color: var(--muted); font-size: .8rem; }
  .experiment-body > div:last-child { display: flex; flex-wrap: wrap; gap: .6rem; }
  .lab-note { display: grid; grid-template-columns: .35fr .65fr; gap: 2rem; }
  .lab-note > div { grid-column: 2; display: grid; grid-template-columns: repeat(2,1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .lab-note > div p { margin: 0; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 1.2rem; color: var(--muted); font-size: .72rem; }
  @media (max-width: 760px) { .lab-hero,.lab-grid,.lab-note { grid-template-columns: 1fr; } .lab-note > div { grid-column: 1; } }
</style>
