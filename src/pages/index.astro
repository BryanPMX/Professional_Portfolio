---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { experience } from '../data/experience';
import { featuredProjects } from '../data/projects';
import { profile, proofPoints, skillGroups } from '../data/profile';
---

<Layout title="Bryan Perez | AI & Software Engineer" description="AI and software engineer building trustworthy agent workflows, secure platforms, and production full-stack systems.">
  <section class="hero shell">
    <div class="hero-copy reveal is-visible">
      <div class="availability">
        <span class="availability-dot" aria-hidden="true"></span>
        {profile.availability}
      </div>
      <p class="eyebrow">AI & software engineer · El Paso, TX</p>
      <h1 class="display-title">I build systems people can <span class="signal-text">trust.</span></h1>
      <p class="lede">
        Production agent workflows, secure APIs, and full-stack platforms—designed with typed contracts, human review, and operational quality from the start.
      </p>
      <div class="hero-actions">
        <a href="#featured-work" class="button button-primary">View featured work <span aria-hidden="true">↓</span></a>
        <a href={profile.resumeHref} class="button button-secondary" target="_blank" rel="noopener noreferrer">Download résumé</a>
        <a href={profile.linkedin} class="button button-text" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
      </div>
    </div>

    <div class="hero-brief surface reveal is-visible">
      <div class="brief-topline">
        <span>Current technical brief</span>
        <span class="brief-live"><i></i> Updated Jul 2026</span>
      </div>
      <div class="brief-flow" aria-label="Bryan's engineering approach: model, guardrail, human review, production">
        <div class="flow-node"><span>01</span><strong>Model</strong><small>intent + context</small></div>
        <div class="flow-line"><span></span></div>
        <div class="flow-node accent"><span>02</span><strong>Guardrail</strong><small>typed decisions</small></div>
        <div class="flow-line"><span></span></div>
        <div class="flow-node warm"><span>03</span><strong>Review</strong><small>human authority</small></div>
        <div class="flow-line"><span></span></div>
        <div class="flow-node"><span>04</span><strong>Ship</strong><small>observe + learn</small></div>
      </div>
      <div class="brief-note">
        <p>Engineering focus</p>
        <strong>AI that can explain when it should stop.</strong>
        <span>Plus the product, data, and infrastructure work required to make it useful.</span>
      </div>
    </div>
  </section>

  <section class="proof section-rule" aria-label="Selected engineering scope">
    <div class="shell proof-grid">
      {proofPoints.map((point) => (
        <div class="proof-item reveal">
          <strong>{point.value}</strong>
          <p>{point.label}</p>
          <span>{point.context}</span>
        </div>
      ))}
    </div>
  </section>

  <section id="featured-work" class="section-pad shell">
    <div class="section-heading reveal">
      <div>
        <p class="eyebrow">Selected systems</p>
        <h2 class="section-title">Evidence over adjectives.</h2>
      </div>
      <p class="lede">Four systems that show agent design, production ownership, security, and cross-platform delivery. Each case study is structured for a fast recruiter scan and a deeper technical interview.</p>
    </div>

    <div class="projects-grid">
      {featuredProjects.map((project, index) => <ProjectCard project={project} index={index} />)}
    </div>
  </section>

  <section class="section-pad section-rule">
    <div class="shell experience-grid">
      <div class="experience-heading reveal">
        <p class="eyebrow">Production experience</p>
        <h2 class="section-title">From agent state machines to deployed platforms.</h2>
        <p class="lede">I work across the seams—where models meet tools, APIs meet clients, and prototypes meet operational constraints.</p>
        <a href="/about" class="button button-secondary">Full experience</a>
      </div>

      <div class="experience-list">
        {experience.map((item, index) => (
          <article class="experience-item reveal">
            <div class="experience-index">0{index + 1}</div>
            <div>
              <div class="experience-meta"><span>{item.period}</span><span>{item.location}</span></div>
              <h3>{item.role}</h3>
              <p class="organization">{item.organization}</p>
              <p>{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad shell">
    <div class="capabilities-heading reveal">
      <p class="eyebrow">Working range</p>
      <h2 class="section-title">Depth where reliability matters. Range where products need it.</h2>
    </div>
    <div class="capabilities-grid">
      {skillGroups.map((group, index) => (
        <article class="capability reveal">
          <span>0{index + 1}</span>
          <h3>{group.label}</h3>
          <ul class="tag-list">
            {group.skills.map((skill) => <li class="tag">{skill}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="closing shell reveal">
    <p class="eyebrow">Open to the next hard problem</p>
    <h2>Need an engineer who can move between <span>AI behavior</span> and production reality?</h2>
    <div>
      <a href="/contact" class="button button-primary">Start a conversation</a>
      <a href={`mailto:${profile.email}`} class="button button-secondary">{profile.email}</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    min-height: calc(100svh - 6.5rem);
    grid-template-columns: minmax(0, 1.08fr) minmax(25rem, 0.92fr);
    align-items: center;
    gap: clamp(3rem, 7vw, 7rem);
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .hero-copy { display: flex; flex-direction: column; align-items: flex-start; gap: 1.55rem; }
  .availability { display: inline-flex; align-items: center; gap: 0.55rem; border: 1px solid var(--line); border-radius: 999px; padding: 0.52rem 0.8rem; background: rgba(255,255,255,.035); color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .66rem; }
  .availability-dot { width: .48rem; height: .48rem; border-radius: 50%; background: var(--signal); box-shadow: 0 0 .8rem rgba(103,232,210,.75); }
  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: .65rem; margin-top: .5rem; }
  .hero-brief { overflow: hidden; padding: 1.2rem; }
  .brief-topline { display: flex; align-items: center; justify-content: space-between; gap: 1rem; border-bottom: 1px solid var(--line); padding: .1rem .15rem 1rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .61rem; text-transform: uppercase; }
  .brief-live { display: flex; align-items: center; gap: .4rem; }
  .brief-live i { width: .4rem; height: .4rem; border-radius: 50%; background: var(--signal); }
  .brief-flow { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr; align-items: center; gap: .3rem; padding: 3rem .2rem; }
  .flow-node { display: flex; min-width: 0; aspect-ratio: 1; flex-direction: column; align-items: center; justify-content: center; border: 1px solid var(--line); border-radius: 1rem; background: rgba(255,255,255,.035); text-align: center; }
  .flow-node span { color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .55rem; }
  .flow-node strong { margin-top: .4rem; font-size: .72rem; }
  .flow-node small { margin-top: .2rem; color: var(--muted); font-size: .53rem; }
  .flow-node.accent { border-color: rgba(103,232,210,.4); box-shadow: 0 0 2rem rgba(103,232,210,.08); }
  .flow-node.warm { border-color: rgba(255,181,107,.35); }
  .flow-line { width: 1rem; height: 1px; overflow: hidden; background: var(--line); }
  .flow-line span { display: block; width: .45rem; height: 1px; background: var(--signal); animation: flow-pulse 2.2s linear infinite; }
  .flow-line:nth-of-type(2) span { animation-delay: -.7s; }
  .flow-line:nth-of-type(3) span { animation-delay: -1.4s; }
  @keyframes flow-pulse { from { transform: translateX(-100%); } to { transform: translateX(230%); } }
  .brief-note { border: 1px solid var(--line); border-radius: 1rem; padding: 1.25rem; background: rgba(4,7,11,.5); }
  .brief-note p, .brief-note strong, .brief-note span { display: block; }
  .brief-note p { margin: 0 0 .7rem; color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .62rem; text-transform: uppercase; }
  .brief-note strong { font-size: 1rem; }
  .brief-note span { margin-top: .45rem; color: var(--muted); font-size: .75rem; }
  .proof { padding-block: 1.6rem; }
  .proof-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .proof-item { border-right: 1px solid var(--line); padding: 1rem clamp(1rem, 3vw, 2rem); }
  .proof-item:first-child { padding-left: 0; }
  .proof-item:last-child { border-right: 0; }
  .proof-item strong { display: block; color: var(--signal); font-size: clamp(1.45rem, 2.5vw, 2.1rem); letter-spacing: -.05em; line-height: 1; }
  .proof-item p { margin: .55rem 0 .18rem; font-size: .76rem; }
  .proof-item span { color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .58rem; }
  .section-heading { display: flex; align-items: end; justify-content: space-between; gap: 3rem; margin-bottom: 3rem; }
  .section-heading h2 { margin-top: 1rem; }
  .section-heading .lede { max-width: 34rem; font-size: .95rem; }
  .projects-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1.1rem; }
  .experience-grid { display: grid; grid-template-columns: minmax(0,.82fr) minmax(0,1.18fr); gap: clamp(3rem,8vw,8rem); }
  .experience-heading { align-self: start; position: sticky; top: 8rem; }
  .experience-heading h2 { margin: 1rem 0 1.2rem; }
  .experience-heading .lede { font-size: .95rem; }
  .experience-heading .button { margin-top: 1.7rem; }
  .experience-list { border-top: 1px solid var(--line); }
  .experience-item { display: grid; grid-template-columns: 2.4rem 1fr; gap: 1.2rem; border-bottom: 1px solid var(--line); padding-block: 2rem; }
  .experience-index { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .65rem; }
  .experience-meta { display: flex; align-items: center; justify-content: space-between; gap: 1rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .63rem; }
  .experience-item h3 { margin: 1rem 0 0; font-size: 1.35rem; letter-spacing: -.03em; }
  .experience-item .organization { margin: .2rem 0 .8rem; color: var(--signal); font-size: .8rem; }
  .experience-item p:last-child { margin: 0; color: var(--muted); font-size: .82rem; }
  .capabilities-heading { display: grid; grid-template-columns: .42fr .58fr; gap: 2rem; align-items: start; margin-bottom: 3rem; }
  .capabilities-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .capability { min-height: 15rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: clamp(1.5rem,3vw,2.4rem); }
  .capability > span { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .64rem; }
  .capability h3 { margin: 2.6rem 0 1.2rem; font-size: 1.15rem; text-transform: capitalize; }
  .closing { margin-bottom: clamp(4.5rem,9vw,8rem); border: 1px solid var(--line); border-radius: 1.35rem; padding: clamp(2rem,6vw,5rem); background: radial-gradient(circle at 80% 20%, rgba(103,232,210,.1), transparent 30%), rgba(14,19,27,.82); }
  .closing h2 { max-width: 20ch; margin: 1.2rem 0 2rem; font-size: clamp(1.8rem,4vw,3.4rem); font-weight: 600; letter-spacing: -.05em; line-height: 1.08; }
  .closing h2 span { color: var(--signal); }
  .closing > div { display: flex; flex-wrap: wrap; gap: .65rem; }

  @media (max-width: 980px) {
    .hero { min-height: auto; grid-template-columns: 1fr; }
    .hero-brief { max-width: 42rem; }
    .proof-grid { grid-template-columns: repeat(2,1fr); }
    .proof-item:nth-child(2) { border-right: 0; }
    .proof-item:nth-child(n+3) { border-top: 1px solid var(--line); }
    .proof-item:nth-child(3) { padding-left: 0; }
  }
  @media (max-width: 760px) {
    .section-heading, .capabilities-heading, .experience-grid { display: grid; grid-template-columns: 1fr; }
    .experience-heading { position: static; }
    .projects-grid, .capabilities-grid { grid-template-columns: 1fr; }
    .brief-flow { grid-template-columns: 1fr 1fr; gap: .6rem; }
    .flow-line { display: none; }
    .flow-node { aspect-ratio: auto; min-height: 6rem; }
  }
  @media (prefers-reduced-motion: reduce) { .flow-line span { animation: none; } }
</style>
