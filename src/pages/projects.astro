---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="Selected Work" description="Selected AI, full-stack, platform, and infrastructure case studies by Bryan Perez.">
  <section class="work-hero section-pad shell reveal is-visible">
    <p class="eyebrow">Selected work · 2023–2026</p>
    <div class="work-hero__grid">
      <h1 class="page-title">Systems designed to hold up <span class="signal-text">under pressure.</span></h1>
      <div>
        <p class="lede">The projects below lead with the problem, Bryan’s ownership, architecture, controls, and evidence—not a wall of technology logos.</p>
        <div class="scan-key">
          <span><i class="production"></i> Production</span>
          <span><i class="private"></i> Private</span>
          <span><i class="personal"></i> Independent</span>
        </div>
      </div>
    </div>
  </section>

  <section class="work-list section-pad section-rule">
    <div class="shell projects-grid">
      {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
    </div>
  </section>

  <section class="case-study-standard section-pad shell reveal">
    <div>
      <p class="eyebrow">How to read the work</p>
      <h2 class="section-title">Every case study follows the same evidence contract.</h2>
    </div>
    <ol>
      <li><span>01</span><div><strong>Context and problem</strong><p>Who the system serves, the constraints it faced, and why it needed to exist.</p></div></li>
      <li><span>02</span><div><strong>Ownership and decisions</strong><p>What Bryan personally built, where the team contributed, and the tradeoffs behind the architecture.</p></div></li>
      <li><span>03</span><div><strong>Quality and evidence</strong><p>Security, reliability, tests, observability, scale, and recruiter-facing product media.</p></div></li>
    </ol>
  </section>
</Layout>

<style>
  .work-hero { padding-top: clamp(5rem,10vw,8.5rem); }
  .work-hero__grid { display: grid; grid-template-columns: minmax(0,1.18fr) minmax(19rem,.82fr); gap: clamp(3rem,8vw,8rem); align-items: end; margin-top: 1.4rem; }
  .work-hero__grid .lede { font-size: 1rem; }
  .scan-key { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.5rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .62rem; }
  .scan-key span { display: flex; align-items: center; gap: .38rem; }
  .scan-key i { width: .45rem; height: .45rem; border-radius: 50%; background: var(--signal); }
  .scan-key .private { background: var(--warm); }
  .scan-key .personal { background: var(--violet); }
  .projects-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 1.1rem; }
  .case-study-standard { display: grid; grid-template-columns: minmax(0,.9fr) minmax(0,1.1fr); gap: clamp(3rem,8vw,8rem); }
  .case-study-standard h2 { margin-top: 1rem; }
  ol { margin: 0; border-top: 1px solid var(--line); padding: 0; list-style: none; }
  li { display: grid; grid-template-columns: 2.5rem 1fr; gap: 1.2rem; border-bottom: 1px solid var(--line); padding: 1.5rem 0; }
  li > span { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .65rem; }
  li strong { font-size: .92rem; }
  li p { margin: .5rem 0 0; color: var(--muted); font-size: .78rem; }
  @media (max-width: 760px) { .work-hero__grid, .projects-grid, .case-study-standard { grid-template-columns: 1fr; } }
</style>

