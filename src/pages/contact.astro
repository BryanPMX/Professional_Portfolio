---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
---

<Layout title="Contact" description="Contact Bryan Perez about software engineering, AI engineering, and product roles.">
  <section class="contact-hero section-pad shell reveal is-visible">
    <div>
      <p class="eyebrow">Contact</p>
      <h1 class="page-title">Let’s talk about the system your team needs to <span class="signal-text">trust next.</span></h1>
    </div>
    <div>
      <p class="lede">The fastest route is email. Share the role or problem, the team context, and what success should look like.</p>
      <a href={`mailto:${profile.email}?subject=Portfolio%20conversation`} class="email-link">{profile.email} <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  <section class="contact-options section-rule section-pad">
    <div class="shell contact-grid">
      <a href={`mailto:${profile.email}?subject=Portfolio%20conversation`} class="contact-card surface hover-lift reveal">
        <span>01 / Email</span><strong>{profile.email}</strong><p>Best for roles, project context, and detailed introductions.</p><i aria-hidden="true">↗</i>
      </a>
      <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="contact-card surface hover-lift reveal">
        <span>02 / LinkedIn</span><strong>linkedin.com/in/brpmx</strong><p>Professional background, shared connections, and concise messages.</p><i aria-hidden="true">↗</i>
      </a>
      <a href={profile.github} target="_blank" rel="noopener noreferrer" class="contact-card surface hover-lift reveal">
        <span>03 / GitHub</span><strong>github.com/BryanPMX</strong><p>Repositories, code history, and the implementation layer behind the work.</p><i aria-hidden="true">↗</i>
      </a>
      <a href={profile.phoneHref} class="contact-card surface hover-lift reveal">
        <span>04 / Phone</span><strong>{profile.phone}</strong><p>For a scheduled conversation after an introduction.</p><i aria-hidden="true">↗</i>
      </a>
    </div>
  </section>

  <section class="contact-detail section-pad shell">
    <div class="availability-panel reveal">
      <p class="eyebrow">Current status</p>
      <h2>{profile.availability}.</h2>
      <dl>
        <div><dt>Location</dt><dd>{profile.location}</dd></div>
        <div><dt>Timezone</dt><dd>{profile.timezone}</dd></div>
        <div><dt>Focus</dt><dd>AI engineering · software engineering · full-stack product</dd></div>
      </dl>
    </div>
    <div class="message-guide surface reveal">
      <p class="eyebrow">A useful first message</p>
      <ol>
        <li><span>01</span><p><strong>Context</strong> — the role, product, or system your team is building.</p></li>
        <li><span>02</span><p><strong>Constraint</strong> — the hardest technical or organizational boundary.</p></li>
        <li><span>03</span><p><strong>Outcome</strong> — what a strong first 90 days or project result would look like.</p></li>
      </ol>
      <a href={`mailto:${profile.email}?subject=Portfolio%20conversation&body=Context%3A%0A%0AConstraint%3A%0A%0AOutcome%3A%0A`} class="button button-primary">Draft email</a>
    </div>
  </section>
</Layout>

<style>
  .contact-hero { display: grid; grid-template-columns: minmax(0,1.15fr) minmax(20rem,.85fr); gap: clamp(3rem,8vw,8rem); align-items: end; padding-top: clamp(5rem,10vw,8.5rem); }
  .contact-hero h1 { margin-top: 1rem; }
  .contact-hero .lede { font-size: 1rem; }
  .email-link { display: inline-flex; gap: .5rem; margin-top: 1.4rem; border-bottom: 1px solid rgba(103,232,210,.45); padding-bottom: .25rem; color: var(--signal); font-size: clamp(.84rem,2vw,1rem); }
  .contact-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1rem; }
  .contact-card { display: grid; min-height: 15rem; grid-template-columns: 1fr auto; padding: clamp(1.4rem,3vw,2rem); }
  .contact-card > span { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .62rem; }
  .contact-card strong { grid-column: 1/-1; align-self: end; overflow-wrap: anywhere; font-size: clamp(1rem,2.1vw,1.45rem); letter-spacing: -.03em; }
  .contact-card p { margin: .55rem 0 0; color: var(--muted); font-size: .72rem; }
  .contact-card i { grid-column: 2; grid-row: 1; color: var(--muted); font-size: 1.2rem; font-style: normal; }
  .contact-detail { display: grid; grid-template-columns: minmax(0,.85fr) minmax(0,1.15fr); gap: clamp(3rem,8vw,8rem); }
  .availability-panel h2 { margin: 1.2rem 0 2rem; font-size: clamp(1.75rem,3.2vw,2.8rem); letter-spacing: -.045em; line-height: 1.15; }
  dl { margin: 0; }
  dl div { display: grid; grid-template-columns: 7rem 1fr; border-top: 1px solid var(--line); padding: .8rem 0; }
  dt { color: var(--muted); font-family: 'JetBrains Mono', monospace; font-size: .62rem; text-transform: uppercase; }
  dd { margin: 0; font-size: .72rem; }
  .message-guide { padding: clamp(1.4rem,4vw,2.5rem); }
  .message-guide ol { margin: 1.5rem 0 2rem; padding: 0; list-style: none; }
  .message-guide li { display: grid; grid-template-columns: 2.5rem 1fr; gap: 1rem; border-top: 1px solid var(--line); padding: 1rem 0; }
  .message-guide li > span { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .61rem; }
  .message-guide p { margin: 0; color: var(--muted); font-size: .76rem; }
  .message-guide strong { color: var(--ink); }
  @media (max-width: 760px) { .contact-hero,.contact-grid,.contact-detail { grid-template-columns: 1fr; } }
</style>
