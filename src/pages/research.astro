---
import Layout from '../layouts/Layout.astro';

const studies = [
  {
    index: '01',
    title: 'Music-key classification with SVM',
    question: 'How effectively can engineered audio features and dimensionality reduction distinguish musical keys?',
    method: 'Extracted audio features, reduced feature space with PCA, and tuned an SVM classifier across a 24-key classification problem.',
    evidence: ['Audio feature extraction', 'Principal component analysis', 'SVM classification', 'Model tuning'],
    caution: 'The portfolio intentionally avoids presenting a headline accuracy without the dataset, baseline, split strategy, and per-class results alongside it.',
    repository: 'https://github.com/BryanPMX/svm-music-key-detection',
  },
  {
    index: '02',
    title: 'LunarLander reinforcement learning',
    question: 'How do DQN and PPO behave under reward shaping, replay, and repeated evaluation?',
    method: 'Compared DQN and PPO experiments using replay buffers, reward shaping, and multi-seed evaluation to separate algorithm behavior from a lucky run.',
    evidence: ['DQN', 'PPO', 'Replay buffers', 'Reward shaping', 'Multi-seed evaluation'],
    caution: 'The useful output is the experimental method and failure analysis—not a cherry-picked episode recording.',
    repository: 'https://github.com/BryanPMX/gymnasium-RL-research',
  },
];
---

<Layout title="Applied ML Research" description="Applied machine-learning research in music-key classification and reinforcement learning by Bryan Perez.">
  <section class="research-hero section-pad shell reveal is-visible">
    <div>
      <p class="eyebrow">Applied ML research</p>
      <h1 class="page-title">Experiments built to expose <span class="signal-text">what the model misses.</span></h1>
    </div>
    <p class="lede">Research is most useful when the setup, baseline, evaluation method, and limitations are visible. These studies support my production AI work with disciplined experimentation.</p>
  </section>

  <section class="study-section section-rule section-pad">
    <div class="shell study-list">
      {studies.map((study) => (
        <article class="study reveal">
          <div class="study-index">{study.index}</div>
          <div class="study-main">
            <p class="eyebrow">Research study</p>
            <h2>{study.title}</h2>
            <p class="question">{study.question}</p>
            <div class="study-detail">
              <div><span>Method</span><p>{study.method}</p></div>
              <div><span>Interpretation guardrail</span><p>{study.caution}</p></div>
            </div>
            <ul class="tag-list">{study.evidence.map((item) => <li class="tag">{item}</li>)}</ul>
            <a href={study.repository} class="button button-secondary" target="_blank" rel="noopener noreferrer">View repository ↗</a>
          </div>
          <div class="study-visual" aria-hidden="true">
            <div class="axis axis-x"></div><div class="axis axis-y"></div>
            <span style="--x:18%;--y:58%"></span><span style="--x:35%;--y:32%"></span><span style="--x:51%;--y:46%"></span><span style="--x:67%;--y:20%"></span><span style="--x:81%;--y:37%"></span>
            <svg viewBox="0 0 100 70"><path d="M4 58 C22 55 25 32 42 38 S62 48 72 25 S88 18 97 10" /></svg>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="research-principles section-pad shell reveal">
    <div><p class="eyebrow">Evaluation principles</p><h2 class="section-title">The same habits transfer to agent systems.</h2></div>
    <div class="principles-grid">
      <div><span>01</span><strong>Repeat the run</strong><p>Use multiple seeds or stable evaluation sets instead of trusting one impressive trace.</p></div>
      <div><span>02</span><strong>Keep the baseline</strong><p>Improvement only means something when the comparison and measurement remain visible.</p></div>
      <div><span>03</span><strong>Inspect failure</strong><p>Confusion, reward hacking, and weak edge cases teach more than a single aggregate score.</p></div>
    </div>
  </section>
</Layout>

<style>
  .research-hero { display: grid; grid-template-columns: minmax(0,1.1fr) minmax(20rem,.9fr); gap: clamp(3rem,8vw,8rem); align-items: end; padding-top: clamp(5rem,10vw,8.5rem); }
  .research-hero h1 { margin-top: 1rem; }
  .research-hero .lede { font-size: 1rem; }
  .study-list { display: grid; gap: 1rem; }
  .study { display: grid; grid-template-columns: 3rem minmax(0,1.15fr) minmax(17rem,.85fr); gap: clamp(1rem,4vw,3rem); border: 1px solid var(--line); border-radius: 1.2rem; padding: clamp(1.2rem,4vw,2.5rem); background: rgba(12,17,24,.72); }
  .study-index { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .65rem; }
  .study h2 { margin: 1rem 0 .8rem; font-size: clamp(1.4rem,2.8vw,2.25rem); letter-spacing: -.04em; line-height: 1.14; }
  .question { margin: 0; color: var(--ink); font-size: .9rem; }
  .study-detail { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin: 1.8rem 0; }
  .study-detail span { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .61rem; text-transform: uppercase; }
  .study-detail p { margin: .5rem 0 0; color: var(--muted); font-size: .72rem; }
  .study .button { margin-top: 1.6rem; }
  .study-visual { position: relative; align-self: stretch; min-height: 20rem; overflow: hidden; border: 1px solid var(--line); border-radius: 1rem; background: radial-gradient(circle at 70% 20%,rgba(169,155,255,.1),transparent 35%),#0a0f16; }
  .study-visual::before { position: absolute; inset: 0; content: ''; opacity: .35; background-image: linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px); background-size: 2.5rem 2.5rem; }
  .axis { position: absolute; z-index: 1; background: rgba(255,255,255,.3); }
  .axis-x { right: 10%; bottom: 14%; left: 12%; height: 1px; }
  .axis-y { top: 12%; bottom: 14%; left: 12%; width: 1px; }
  .study-visual span { position: absolute; z-index: 2; top: var(--y); left: var(--x); width: .48rem; height: .48rem; border-radius: 50%; background: var(--signal); box-shadow: 0 0 .8rem rgba(103,232,210,.6); }
  .study-visual svg { position: absolute; z-index: 1; right: 8%; bottom: 13%; left: 12%; width: 80%; height: 72%; overflow: visible; }
  .study-visual path { fill: none; stroke: var(--violet); stroke-width: .6; opacity: .8; }
  .research-principles { display: grid; grid-template-columns: minmax(0,.8fr) minmax(0,1.2fr); gap: clamp(3rem,8vw,8rem); }
  .research-principles h2 { margin-top: 1rem; }
  .principles-grid { border-top: 1px solid var(--line); }
  .principles-grid > div { display: grid; grid-template-columns: 2.5rem 11rem 1fr; gap: 1rem; border-bottom: 1px solid var(--line); padding: 1.35rem 0; }
  .principles-grid span { color: var(--signal); font-family: 'JetBrains Mono', monospace; font-size: .62rem; }
  .principles-grid strong { font-size: .78rem; }
  .principles-grid p { margin: 0; color: var(--muted); font-size: .72rem; }
  @media (max-width: 850px) { .research-hero,.study,.research-principles { grid-template-columns: 1fr; } .study-visual { min-height: 16rem; } }
  @media (max-width: 560px) { .study-detail { grid-template-columns: 1fr; } .principles-grid > div { grid-template-columns: 2rem 1fr; } .principles-grid p { grid-column: 2; } }
</style>
