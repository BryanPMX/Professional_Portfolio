<style>
  .ambient-background {
    position: fixed;
    z-index: -2;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  svg {
    width: 100%;
    height: 100%;
    opacity: 0.56;
  }

  .network path {
    fill: none;
    stroke: url(#network-line);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .network circle {
    fill: url(#node-fill);
    transform-box: fill-box;
    transform-origin: center;
  }

  .network-a {
    animation: network-drift 20s ease-in-out infinite alternate;
  }

  .network-b {
    opacity: 0.5;
    animation: network-drift-reverse 25s ease-in-out infinite alternate;
  }

  .network circle {
    animation: node-pulse 4.5s ease-in-out infinite;
  }

  .network circle:nth-of-type(2n) {
    animation-delay: -2s;
  }

  @keyframes network-drift {
    to { transform: translate3d(1.8rem, -1rem, 0); }
  }

  @keyframes network-drift-reverse {
    to { transform: translate3d(-1.4rem, 1.2rem, 0); }
  }

  @keyframes node-pulse {
    50% { opacity: 0.38; transform: scale(0.65); }
  }

  :global(html.motion-paused) .network,
  :global(html.motion-paused) .network circle {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .network,
    .network circle {
      animation: none;
