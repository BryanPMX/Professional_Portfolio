---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const statusLabels = {
  private: 'Private product',
  personal: 'Independent build',
  production: 'Production platform',
};
---

<article class="project-card surface hover-lift">
  <a href={`/projects/${project.slug}`} class="project-card__link" aria-label={`Read the ${project.title} case study`}>
    <div class="project-card__visual" aria-hidden="true">
      <span class="project-number">0{index + 1}</span>
      <div class="project-network">
        <span class="network-node node-a"></span>
        <span class="network-node node-b"></span>
        <span class="network-node node-c"></span>
        <span class="network-line line-a"></span>
        <span class="network-line line-b"></span>
      </div>
      <div class="project-card__metric">
        <strong>{project.metrics[0].value}</strong>
        <span>{project.metrics[0].label}</span>
      </div>
    </div>

    <div class="project-card__body">
      <div class="project-card__meta">
        <span>{statusLabels[project.status]}</span>
        <span>{project.period}</span>
      </div>
      <p class="project-card__kicker">{project.kicker}</p>
      <div class="project-card__title-row">
        <h2>{project.title}</h2>
        <span class="project-arrow">↗</span>
      </div>
      <p class="project-card__summary">{project.summary}</p>
      <ul class="tag-list" aria-label={`${project.title} technologies`}>
        {project.technologies.slice(0, 5).map((technology) => <li class="tag">{technology}</li>)}
      </ul>
    </div>
  </a>
</article>

<style>
  .project-card {
    min-height: 100%;
    overflow: hidden;
  }

  .project-card__link {
    display: grid;
    min-height: 100%;
    grid-template-rows: auto 1fr;
  }

  .project-card__visual {
    position: relative;
    min-height: 15rem;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(135deg, rgba(103, 232, 210, 0.08), transparent 45%),
      radial-gradient(circle at 75% 30%, rgba(169, 155, 255, 0.14), transparent 32%),
      #0b1017;
  }

  .project-card__visual::before {
    position: absolute;
    inset: 0;
    content: '';
    opacity: 0.38;
    background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 2.75rem 2.75rem;
    mask-image: linear-gradient(135deg, black, transparent 80%);
  }

  .project-number {
    position: absolute;
    z-index: 1;
    top: 1.2rem;
    left: 1.3rem;
    color: rgba(244, 242, 235, 0.36);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
  }

  .project-network {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12rem;
    height: 7rem;
    transform: translate(-50%, -50%);
  }

  .network-node {
    position: absolute;
    z-index: 2;
    display: grid;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid rgba(103, 232, 210, 0.45);
    border-radius: 0.7rem;
    background: #101b20;
    box-shadow: 0 0 2rem rgba(103, 232, 210, 0.13);
  }

  .network-node::after {
    width: 0.42rem;
    height: 0.42rem;
    margin: auto;
    border-radius: 50%;
    content: '';
    background: var(--signal);
    box-shadow: 0 0 0.75rem var(--signal);
  }

  .node-a { top: 0; left: 0; }
  .node-b { top: 2.4rem; left: 4.9rem; border-color: rgba(169, 155, 255, 0.55); }
  .node-b::after { background: var(--violet); box-shadow: 0 0 0.75rem var(--violet); }
  .node-c { right: 0; bottom: 0; }

  .network-line {
    position: absolute;
    z-index: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(103, 232, 210, 0.5), rgba(169, 155, 255, 0.5));
    transform-origin: left;
  }

  .line-a { top: 1.5rem; left: 1.8rem; width: 5.3rem; transform: rotate(28deg); }
  .line-b { top: 4.2rem; left: 6.6rem; width: 4.8rem; transform: rotate(18deg); }

  .project-card__metric {
    position: absolute;
    z-index: 2;
    right: 1rem;
    bottom: 1rem;
    max-width: 9.5rem;
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    padding: 0.7rem 0.85rem;
    background: rgba(8, 11, 16, 0.82);
    backdrop-filter: blur(0.8rem);
  }

  .project-card__metric strong,
  .project-card__metric span { display: block; }
  .project-card__metric strong { color: var(--signal); font-size: 0.92rem; }
  .project-card__metric span { margin-top: 0.2rem; color: var(--muted); font-size: 0.62rem; line-height: 1.35; }

  .project-card__body {
    display: flex;
    flex-direction: column;
    padding: clamp(1.35rem, 3vw, 2rem);
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.63rem;
    text-transform: uppercase;
  }

  .project-card__kicker {
    margin: 1.55rem 0 0.4rem;
    color: var(--signal);
    font-size: 0.75rem;
  }

  .project-card__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.045em;
  }

  .project-arrow {
    display: grid;
    width: 2.5rem;
    height: 2.5rem;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 50%;
    color: var(--muted);
    transition: background 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .project-card__link:hover .project-arrow {
    background: var(--signal);
    color: #05110f;
    transform: rotate(8deg);
  }

  .project-card__summary {
    flex: 1;
    margin: 1rem 0 1.35rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }
</style>
